# Server
PORT=4178
DATABASE_PATH=server/data/leadflow.sqlite
PHONE_DEFAULT_COUNTRY_CODE=+91

# OpenRouter real AI message generation
# Strictly free-only: leave OPENROUTER_MODEL as openrouter/free or use a model id ending in :free.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_HTTP_REFERER=http://127.0.0.1:4178
OPENROUTER_APP_TITLE=EFOS LeadFlow
OPENROUTER_TIMEOUT_MS=12000

# Optional OpenAI fallback if OpenRouter is not configured
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_TIMEOUT_MS=12000

# Supabase cloud database
# Use the service role key only on the server. Never expose it in frontend code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# SMTP real email sending
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Twilio-compatible SMS sending
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+15551234567

# Twilio-compatible WhatsApp sending
TWILIO_WHATSAPP_FROM=whatsapp:+15551234567

# Optional Twilio Messaging Service for SMS
TWILIO_MESSAGING_SERVICE_SID=

# n8n / Zapier / Make / AgentHive webhook
FOLLOWUP_WEBHOOK_URL=

